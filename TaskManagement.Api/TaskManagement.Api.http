@TaskManagement.Api_HostAddress = http://localhost:5275

GET {{TaskManagement.Api_HostAddress}}/weatherforecast/
Accept: application/json

###

# MCP - Get available tools
GET {{TaskManagement.Api_HostAddress}}/api/mcp/tools
Accept: application/json

###

# MCP - Execute tool: get_user_weekly_tasks
POST {{TaskManagement.Api_HostAddress}}/api/mcp/execute
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "toolName": "get_user_weekly_tasks",
  "parameters": {
    "user_id": "user-123",
    "week": "this"
  }
}

###

# MCP - Execute tool: get_user_work_logs
POST {{TaskManagement.Api_HostAddress}}/api/mcp/execute
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "toolName": "get_user_work_logs",
  "parameters": {
    "user_id": "user-123",
    "week": "all"
  }
}

###

# NLP Query - "Hans bu hafta ne yapti?" (What did Hans do this week?)
POST {{TaskManagement.Api_HostAddress}}/api/mcp/query
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "text": "Hans bu hafta ne yapti?"
}

###

# NLP Query - "What did John do last week?"
POST {{TaskManagement.Api_HostAddress}}/api/mcp/query
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "text": "What did John do last week?"
}

###

# NLP Query - "Show Hans's work logs"
POST {{TaskManagement.Api_HostAddress}}/api/mcp/query
Content-Type: application/json
Authorization: Bearer YOUR_JWT_TOKEN

{
  "text": "Show Hans's work logs"
}

###

# NLP Query - "How much time on ProjectX?"
